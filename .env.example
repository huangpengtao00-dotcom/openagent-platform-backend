APP_ENV=dev
DATABASE_URL=sqlite:///./openagent_platform.db

REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=false
RUN_QUEUE_BACKEND=database
RUN_QUEUE_KEY=openagent:runs:pending

HARNESS_ROOT=../02_OpenAgent_Harness
HOST_HARNESS_ROOT=../02_OpenAgent_Harness
HARNESS_PYTHON=python
HARNESS_PYTHONPATH=src
HARNESS_RUNS_ROOT=./artifacts/harness_runs
HARNESS_DEFAULT_MODEL=deepseek-v4-flash
HARNESS_EXECUTOR=local
HARNESS_DOCKER_IMAGE=openagent-harness:latest
HARNESS_CONTAINER_ROOT=/harness
HARNESS_CONTAINER_RUNS_ROOT=/runs

RATE_LIMIT_RUNS_PER_MINUTE=5
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_NEGATIVE_TTL_SECONDS=60
CACHE_TTL_JITTER_SECONDS=60

ALLOW_REAL_LLM_CALLS=true
AUTO_START_RUNS=true
REAL_API_BUDGET_LIMIT_CNY=1.0
USD_TO_CNY_RATE=7.25

# Optional Harness-side provider keys. Put real values in ../02_OpenAgent_Harness/.env.
NEWAPI_BASE_URL=https://example.com/v1
NEWAPI_5_4_API_KEY=
NEWAPI_5_5_API_KEY=
